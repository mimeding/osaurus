    "One or more Azure deployment names — comma or newline-separated. Stored as the provider's model list." : {
      "comment" : "Help text under the Azure deployments field in the credential sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein oder mehrere Azure-Deployment-Namen – durch Komma oder Zeilenumbruch getrennt. Wird als Modellliste des Anbieters gespeichert."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个或多个 Azure 部署名称——以逗号或换行分隔。将作为该提供方的模型列表存储。"
          }
        }
      }
    },
    "Only Accepted Tokens Enter Base Cache" : {
      "comment" : "Description of a setting that controls whether only tokens that have been accepted by the MTP server are stored in the base cache.",
      "isCommentAutoGenerated" : true,
