    "Let agents use built-in and plugin tools. Turn off to send messages directly to the model with no tool specs or capability injection (chat-only)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Let agents use built-in and plugin tools. Turn off to send messages directly to the model with no tool specs or capability injection (chat-only)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许代理使用内置工具和插件工具。关闭此选项，则消息将直接发送给模型，不附带任何工具规格或能力注入（纯聊天模式）。"
          }
        }
      }
    },
    "Let requests run with no time limit" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anfragen ohne Zeitlimit ausführen"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让请求在无时间限制下运行"
          }
        }
      }
    },
    "Let the agent act between your messages." : {
      "comment" : "Feature toggle row title for \"Self-scheduling\" feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass den Agenten zwischen deinen Nachrichten handeln."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让智能体在你的消息之间采取行动。"
          }
        }
      }
    },
    "Let the agent create its own tools as plugins." : {
      "comment" : "A feature toggle that lets an agent create its own tools as plugins.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass den Agenten eigene Tools als Plugins erstellen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让智能体以插件形式创建自己的工具。"
          }
        }
      }
    },
    "Let the agent run long-lived processes (servers, watchers) detached and manage them. Off by default to keep the tool surface lean." : {
      "comment" : "A description for the \"Background Processes\" feature in the Agent Detail View.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Let the agent run long-lived processes (servers, watchers) detached and manage them. Off by default to keep the tool surface lean."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让代理以分离的方式运行长期进程（服务器、监视器）并管理它们。默认关闭以保持工具界面简洁。"
          }
        }
      }
    },
    "Let the agent schedule its own follow-up runs and send you notifications." : {
      "comment" : "A description of the \"Self-scheduling\" feature in the Agent Detail View.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Let the agent schedule its own follow-up runs and send you notifications."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让代理自行安排后续运行并通知您。"
          }
        }
      }
    },
    "Let the agent schedule its own follow-up runs and send you notifications. Turn on to choose how often it can run." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass den Agenten eigene Folgeläufe planen und dir Benachrichtigungen senden. Aktiviere dies, um festzulegen, wie oft er laufen darf."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让智能体自行安排后续运行并向你发送通知。开启后可选择它的运行频率。"
          }
        }
      }
    },
    "Let the agent search its own memory mid-conversation to pull up past details on demand. Separate from Memory above, which only auto-injects and saves." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass den Agenten während des Gesprächs seinen eigenen Speicher durchsuchen, um bei Bedarf vergangene Details abzurufen. Getrennt von „Speicher“ oben, der nur automatisch einfügt und speichert."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让智能体在对话过程中搜索自己的记忆，按需调取过去的细节。这与上方的“记忆”不同，后者仅自动注入和保存。"
          }
        }
      }
    },
    "Let the agent use tools to take actions and look things up. Turn off for a chat-only agent." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass den Agenten Tools verwenden, um Aktionen auszuführen und Dinge nachzuschlagen. Deaktiviere dies für einen reinen Chat-Agenten."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让智能体使用工具来执行操作和查找信息。如需仅聊天的智能体，请关闭此项。"
          }
        }
      }
    },
    "Let the model invoke tools without an explicit `tool_choice` from the client." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
