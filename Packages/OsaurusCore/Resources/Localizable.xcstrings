    "Activate copies the agent into ~/.osaurus/agents/<id>/, rekeys its database to your local key, and registers the agent for use. Discard wipes the unpacked scratch directory and changes nothing on disk." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren kopiert den Agenten nach ~/.osaurus/agents/<id>/, verschlüsselt seine Datenbank mit deinem lokalen Schlüssel neu und registriert den Agenten zur Verwendung. Verwerfen löscht das entpackte temporäre Verzeichnis und ändert nichts auf der Festplatte."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“激活”会将该智能体复制到 ~/.osaurus/agents/<id>/，使用你的本地密钥重新加密其数据库，并注册该智能体以供使用。“放弃”会清除已解包的临时目录，且不会更改磁盘上的任何内容。"
          }
        }
      }
    },
