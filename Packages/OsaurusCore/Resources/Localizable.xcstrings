    "Send anonymous crash and freeze reports so we can fix what breaks. Never includes your chats, prompts, files, or keys. Turn off any time." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sende anonyme Absturz- und Hängeberichte, damit wir Fehler beheben können. Niemals enthalten sind deine Chats, Prompts, Dateien oder Schlüssel. Jederzeit abschaltbar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发送匿名崩溃和卡死报告，以便我们修复问题。绝不包含你的聊天、提示词、文件或密钥。可随时关闭。"
          }
        }
      }
    },
    "Send anonymous, aggregated usage analytics to help improve Osaurus. Never includes your chats, prompts, files, or keys. Turn off any time." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sende anonyme, aggregierte Nutzungsanalysen, um Osaurus zu verbessern. Niemals enthalten sind deine Chats, Prompts, Dateien oder Schlüssel. Jederzeit abschaltbar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发送匿名、汇总的使用分析，以帮助改进 Osaurus。绝不包含你的聊天、提示词、文件或密钥。可随时关闭。"
          }
        }
      }
    },
    "Send crash reports" : {
