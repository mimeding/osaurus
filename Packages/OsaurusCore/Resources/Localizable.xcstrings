            "state" : "translated",
            "value" : "Osaurus将在行切换关闭时不会自动连接此MCP提供商。"
          }
        }
      }
    },
    "Osaurus will not auto-connect this provider while the row toggle is off." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
