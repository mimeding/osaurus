    "Fix or remove %@, then save Sandbox settings again." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Korrigieren oder entfernen Sie %@, und speichern Sie dann die Sandbox-Einstellungen erneut."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을(를) 수정하거나 제거한 후, 샌드박스 설정을 다시 저장하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修复或删除%@，然后再次保存沙盒设置。"
          }
        }
      }
    },
    "Fix ownership or permissions for %@, then rerun preflight. For user-owned paths, chmod u+rwX \"%@\" is usually enough." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Beheben Sie das Eigentum oder die Berechtigungen für %1$@ und führen Sie den Vorlauf erneut aus. Für benutzereigene Pfade ist chmod u+rwX \"%2$@\" in der Regel ausreichend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Fix ownership or permissions for %1$@, then rerun preflight. For user-owned paths, chmod u+rwX \"%2$@\" is usually enough."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@의 소유권 또는 권한을 수정한 다음 사전 점검을 다시 실행하세요. 사용자 소유 경로의 경우 보통 chmod u+rwX \"%2$@\"이면 충분합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修复%1$@的所有权或权限，然后重新运行预检。对于用户拥有的路径，通常chmod u+rwX \"%2$@\"就足够了。"
          }
        }
      }
    },
