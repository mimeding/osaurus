          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本地大脑保存在你的 Mac 上。它们运行时会占用一部分内存，并且可以离线工作。"
          }
        }
      }
    },
    "Local endpoints don't usually need a key — leave blank to skip auth." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
