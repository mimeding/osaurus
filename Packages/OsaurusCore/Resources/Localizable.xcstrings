    "privacy.highlight.a11y.inbound" : {
      "comment" : "VoiceOver label for inline-highlighted text in an ASSISTANT bubble whose original was restored by the Privacy Filter unscrubber. %@ is the placeholder token (e.g. [PHONE_1]) the cloud emitted before the unscrubber rewrote it.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wiederhergestellt aus %@. Die Cloud hat nur den Platzhalter gesehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restored from %@. The cloud only saw the placeholder."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@에서 복원되었습니다. 클라우드에는 자리 표시자만 표시되었습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已从 %@ 还原。云端只看到了占位符。"
          }
        }
      }
    },
    "privacy.highlight.a11y.outbound" : {
      "comment" : "VoiceOver label for inline-highlighted text in a USER bubble whose original was scrubbed before send. %@ is the placeholder token (e.g. [PHONE_1]) the cloud actually saw.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als %@ an die Cloud gesendet. Das Original bleibt auf diesem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sent to cloud as %@. The original stays on this device."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클라우드에 %@(으)로 전송되었습니다. 원본은 이 기기에 유지됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以 %@ 形式发送到云端。原始内容保留在此设备上。"
          }
        }
      }
    },
    "privacy.highlight.a11y.preview" : {
      "comment" : "VoiceOver label for highlighted placeholder tokens in the review sheet's scrubbed preview. %@ is the original value the placeholder replaces (e.g. an email or phone number), shown so screen readers can announce what's being hidden from the cloud.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Platzhalter ersetzt %@. Das Original bleibt auf diesem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placeholder replacing %@. The original stays on this device."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을(를) 대체하는 자리 표시자입니다. 원본은 이 기기에 유지됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "占位符替换了 %@。原始内容保留在此设备上。"
          }
        }
      }
    },
    "privacy.install.subtitle" : {
      "comment" : "Idle-state subtitle of the Privacy Filter install hero. Sets expectations on size and on-device runtime before the user clicks Install.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etwa 2,8 GB. Läuft vollständig auf diesem Mac – kein Drittanbieter-Datenverkehr für die Erkennung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "About 2.8 GB. Runs entirely on this Mac — no third-party traffic for detection."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "약 2.8GB입니다. 이 Mac에서 전적으로 실행되며 감지를 위한 타사 트래픽이 발생하지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "约 2.8 GB。完全在此 Mac 上运行——检测过程没有任何第三方流量。"
          }
        }
      }
    },
