          }
        }
      }
    },
    "These models are no longer used. Delete to free up %@." : {
      "comment" : "A paragraph explaining that the app will delete legacy WhisperKit models when the user taps \"Delete\".",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
