      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Use the on-device model to catch names, addresses, dates, and free-form secrets that pattern rules miss. Runs locally; pattern rules in the Rules tab work without it."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "온디바이스 모델을 사용하여 패턴 규칙이 놓치는 이름, 주소, 날짜 및 자유 형식 비밀을 포착합니다. 로컬에서 실행되며, 규칙 탭의 패턴 규칙은 모델 없이도 작동합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用设备端模型捕捉正则规则遗漏的姓名、地址、日期以及自由格式的密钥。模型在本地运行；「规则」标签页中的正则规则无需模型即可正常工作。"
          }
        }
      }
    },
