    "Advertise this agent on your local network via Bonjour so nearby devices can discover it automatically." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mache diesen Agenten über Bonjour in deinem lokalen Netzwerk bekannt, damit Geräte in der Nähe ihn automatisch finden können."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过 Bonjour 在本地网络中公布此智能体，以便附近的设备可以自动发现它。"
          }
        }
      }
    },
    "Affects pause detection, wake word detection, and voice activity thresholds" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
