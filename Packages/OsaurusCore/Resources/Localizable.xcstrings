      }
    },
    "Osaurus can send anonymous usage data to help us understand how it's used and improve it." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus kann anonyme Nutzungsdaten senden, damit wir verstehen, wie die App genutzt wird, und sie verbessern können."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 可以发送匿名使用数据，帮助我们了解应用的使用方式并加以改进。"
          }
        }
      }
    },
    "Osaurus cannot prove runtime behavior until the model bundle is local." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Osaurus kann das Laufzeitverhalten nicht nachweisen, bis das Modell-Bundle lokal ist."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在模型捆绑是本地的之前，Osaurus无法证明运行时行为。"
          }
        }
      }
    },
