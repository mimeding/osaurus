    },
    "We'll keep trying. You can also add tools later from Settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir versuchen es weiter. Du kannst Tools auch später über die Einstellungen hinzufügen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们会继续尝试。你也可以稍后从“设置”中添加工具。"
          }
        }
      }
    },
    "We'll open your browser to sign in. After approving, you'll be redirected back to Osaurus." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir öffnen deinen Browser zur Anmeldung. Nach der Genehmigung wirst du zurück zu Osaurus weitergeleitet."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们将打开你的浏览器以进行登录。批准后，你将被重定向回 Osaurus。"
          }
        }
      }
    },
    "We'll pick the most relevant ones from your enabled set each turn." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir wählen bei jeder Runde die relevantesten aus deinem aktivierten Satz aus."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们会在每一轮从你启用的集合中挑选最相关的项目。"
          }
        }
      }
    },
    "We're keeping the one you already have so nothing you've built breaks." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir behalten die, die du bereits hast, damit nichts kaputtgeht, was du erstellt hast."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们会保留你已有的那个，这样你已构建的内容都不会受损。"
          }
        }
      }
    },
    "We're keeping the signature you have so nothing breaks." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir behalten deine vorhandene Signatur, damit nichts kaputtgeht."
          }
