      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Definiere deine eigenen Regex-Muster – interne Codenamen, Kunden-IDs, alles, was die integrierten Muster von Osaurus nicht abdecken. Fehlerhafte Muster werden vor dem Speichern validiert."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내부 코드명, 고객 ID 등 Osaurus의 기본 제공 항목이 다루지 않는 고유한 정규식 패턴을 정의하세요. 잘못된 패턴은 저장 전에 유효성 검사를 거칩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "定义你自己的正则表达式模式——内部代号、客户 ID 等任何 Osaurus 内置规则未覆盖的内容。错误的模式会在保存前进行校验。"
          }
        }
      }
    },
