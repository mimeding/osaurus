      }
    },
    "This only applies to this chat." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dies gilt nur fuer diesen Chat."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것은 이 채팅에만 적용됩니다."
          }
