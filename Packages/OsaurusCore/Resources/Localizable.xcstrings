      }
    },
    "That OsaurusAI model isn't in the registry. Pick one from the Recommended list." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses OsaurusAI-Modell ist nicht in der Registry. Wähle eines aus der Liste „Empfohlen“."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
