          }
        }
      }
    },
    "The model returned no visible text" : {
      "comment" : "Label for a footer view that appears when the Osaurus Router billed a turn that produced no visible text.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The model returned no visible text"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模型未返回可见文本"
          }
        }
      }
    },
    "The model starts with a small set and loads more from your enabled capabilities on demand." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Das Modell beginnt mit einem kleinen Satz und laed bei Bedarf mehr aus Ihren aktivierten Faehigkeiten."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
