    },
    "Only documented capture capabilities can be requested by plugins." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Only documented capture capabilities can be requested by plugins."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
