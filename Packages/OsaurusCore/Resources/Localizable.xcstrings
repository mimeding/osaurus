    "Themes Needing Review" : {
      "comment" : "Title for a section of the Themes view showing only those themes that need review.",
      "isCommentAutoGenerated" : true
    },
    "These `.mcp.json` entries were malformed (no `command` and no `url`) and couldn't be imported:" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
