    },
    "Only needed if an agent reads the screen visually (screenshots). The standard mode works without it." : {
      "comment" : "Subtitle for a Computer Use permission row that explains when the screen recording permission is optional.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nur erforderlich, wenn ein Agent den Bildschirm visuell liest (Bildschirmfotos). Der Standardmodus funktioniert ohne diese Berechtigung."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
