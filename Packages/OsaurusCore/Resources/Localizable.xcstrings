    "Unload model weights after this much idle time. Must exceed light sleep." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Unload model weights after this much idle time. Must exceed light sleep."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이만큼의 유휴 시간이 지나면 모델 가중치를 언로드합니다. 짧은 절전 모드를 초과해야 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此空闲时长后卸载模型权重。该值必须大于浅度休眠时间。"
          }
        }
      }
    },
    "Unloads model memory as soon as no active chat window or generation lease keeps it warm." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
