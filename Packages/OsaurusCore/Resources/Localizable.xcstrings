        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어느 쪽이든 전체 텍스트 검색 및 모든 기능은 동일하게 작동합니다. 암호화는 디스크에 바이트가 저장되는 방식만 변경합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
