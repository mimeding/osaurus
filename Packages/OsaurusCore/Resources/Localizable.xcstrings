    "OK: bufferTurn inserted a row (%lld → %lld). The buffer path is healthy. Run 'Distill pending' or wait for the debounce." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "OK: bufferTurn hat eine Zeile eingefuegt (%lld → %lld). Der Pufferpfad ist gesund. Fuehren Sie \"Ausstehende destillieren\" aus oder warten Sie auf das Debounce."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "OK: bufferTurn inserted a row (%1$lld → %2$lld). The buffer path is healthy. Run 'Distill pending' or wait for the debounce."
