        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "影响暂停检测、唤醒词检测和语音活动阈值"
          }
        }
      }
    },
    "After each chat, the agent distills the conversation into a short summary. Episodes accumulate here so the agent can recall past sessions." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach jedem Chat verdichtet der Agent das Gespräch zu einer kurzen Zusammenfassung. Episoden sammeln sich hier an, sodass der Agent vergangene Sitzungen abrufen kann."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每次聊天后，智能体会将对话提炼成简短的摘要。情节会在此累积，以便智能体回忆起过去的会话。"
          }
        }
      }
    },
