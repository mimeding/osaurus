    "Off" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "离开"
          }
        }
      }
    },
    "Off binds to 127.0.0.1 (this Mac only). On binds to 0.0.0.0 so phones, iPads, and other devices on your network can connect." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Off binds to 127.0.0.1 (this Mac only). On binds to 0.0.0.0 so phones, iPads, and other devices on your network can connect."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭则仅绑定到127.0.0.1（仅此Mac）。开启则绑定到0.0.0.0，这样手机、iPad和其他网络设备就可以连接。"
          }
        }
      }
    },
    "Off by default. When on, each empty state generates a fresh greeting + quick actions on the configured Core Model. The first generation can feel slow on small models like Foundation; the static greeting still paints instantly. Per-agent overrides in the Customization tab still win." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig deaktiviert. Wenn aktiviert, erzeugt jeder Leerzustand eine neue Begrüßung + Schnellaktionen auf dem konfigurierten Core-Modell. Die erste Generierung kann sich bei kleinen Modellen wie Foundation langsam anfühlen; die statische Begrüßung wird trotzdem sofort angezeigt. Pro-Agent-Overrides im Tab „Anpassung“ haben weiterhin Vorrang."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认关闭。开启后，每个空白状态都会在配置的核心模型上生成全新的问候语和快捷操作。在 Foundation 等小型模型上，首次生成可能会感觉较慢；静态问候语仍会立即显示。“自定义”标签页中的按智能体覆盖项仍然优先。"
          }
        }
      }
    },
    "Off disables speculation. Auto uses it only when the model ships a verified native MTP head. Force-On requires that head." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Off disables speculation. Auto uses it only when the model ships a verified native MTP head. Force-On requires that head."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Off 会禁用推测解码。Auto 仅在模型自带经验证的原生 MTP 头时使用。Force-On 要求该头存在。"
          }
        }
      }
    },
    "Off: access expires in 90 days. On: access never expires until revoked." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus: Zugriff läuft in 90 Tagen ab. An: Zugriff läuft nie ab, bis er widerrufen wird."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭：访问权限将在 90 天后过期。开启：访问权限在被撤销前永不过期。"
          }
        }
      }
    },
    "OK" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OK"
          }
        },
        "zh-Hans" : {
