            "value" : "当前模型仅支持文本。"
          }
        }
      }
    },
    "The current model supports %@ only." : {
      "comment" : "Auto-extracted format-string key (Apple String.LocalizationValue canonical form).",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
