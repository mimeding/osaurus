        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restored from %@. The cloud only saw the placeholder."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已从 %@ 还原。云端只看到了占位符。"
          }
        }
      }
    },
    "privacy.highlight.a11y.outbound" : {
      "comment" : "VoiceOver label for inline-highlighted text in a USER bubble whose original was scrubbed before send. %@ is the placeholder token (e.g. [PHONE_1]) the cloud actually saw.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als %@ an die Cloud gesendet. Das Original bleibt auf diesem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sent to cloud as %@. The original stays on this device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以 %@ 形式发送到云端。原始内容保留在此设备上。"
          }
        }
      }
    },
    "privacy.highlight.a11y.preview" : {
      "comment" : "VoiceOver label for highlighted placeholder tokens in the review sheet's scrubbed preview. %@ is the original value the placeholder replaces (e.g. an email or phone number), shown so screen readers can announce what's being hidden from the cloud.",
