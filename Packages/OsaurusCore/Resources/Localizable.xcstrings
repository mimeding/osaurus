        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "配置文件是无效的 JSON 或形状不兼容。"
          }
        }
      }
    },
    "The container's /workspace directory is bind-mounted from ~/.osaurus/container/workspace/. Open it in Finder to browse or edit files directly on the host." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das /workspace-Verzeichnis des Containers wird per Bind-Mount aus ~/.osaurus/container/workspace/ eingebunden. Öffne es im Finder, um Dateien direkt auf dem Host zu durchsuchen oder zu bearbeiten."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "容器的 /workspace 目录通过绑定挂载方式来自 ~/.osaurus/container/workspace/。在访达中打开它，可直接在主机上浏览或编辑文件。"
          }
        }
      }
    },
    "The current model is text-only." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das aktuelle Modell ist nur für Text."
          }
        },
        "en" : {
          "stringUnit" : {
