    "How image jobs ask for permission and manage GPU memory between runs." : {
      "comment" : "A description of how image jobs interact with the system's GPU resources.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Wie Bildaufträge Berechtigungen anfordern und den GPU-Speicher zwischen Ausführungen verwalten."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "이미지 작업이 실행 간에 권한을 요청하고 GPU 메모리를 관리하는 방법."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "图像任务如何请求权限以及在运行间管理 GPU 显存。"
          }
        }
      }
    },
    "How many prompt tokens are prefilled per step." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "How many prompt tokens are prefilled per step."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "단계별로 미리 채워지는 프롬프트 토큰 수입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一步预填充的提示 token 数量。"
          }
        }
      }
    },
    "How many requests the engine can decode at once. Higher = more throughput, more wired memory." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "How many requests the engine can decode at once. Higher = more throughput, more wired memory."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "엔진이 한 번에 디코딩할 수 있는 요청 수입니다. 값이 높을수록 처리량이 증가하지만 고정된 메모리가 더 많이 필요합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "引擎可同时解码的请求数量。数值越高，吞吐量越大，但占用的固定内存也越多。"
          }
        }
      }
    },
    "How many tokens the draft model proposes before the main model verifies." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "How many tokens the draft model proposes before the main model verifies."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 모델이 확인하기 전에 초안 모델이 제안하는 토큰 수입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "主模型校验前，草案模型先提议的 token 数量。"
          }
        }
      }
    },
    "How often this agent is allowed to run itself in the background. The agent picks its own next time within these bounds." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Wie oft dieser Agent sich selbst im Hintergrund ausführen darf. Der Agent wählt seinen nächsten Zeitpunkt innerhalb dieser Grenzen selbst."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 에이전트가 백그라운드에서 실행되도록 허용되는 빈도입니다. 에이전트는 이 범위 내에서 다음 실행 시간을 스스로 선택합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此智能体被允许在后台自行运行的频率。智能体将在此范围内自行选择下次运行时间。"
          }
        }
      }
    },
