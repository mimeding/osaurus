          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하나 이상의 검사를 증명할 수 없습니다. 지원 또는 CI 증명을 위해 보고서를 복사하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个或多个检查无法被证明；复制报告以供支持或CI证明。"
          }
        }
      }
    },
    "Only Accepted Tokens Enter Base Cache" : {
      "comment" : "Description of a setting that controls whether only tokens that have been accepted by the MTP server are stored in the base cache.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
