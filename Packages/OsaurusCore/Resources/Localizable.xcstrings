        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的聊天记录保存在你的Mac上。推理运算在 Venice 的硬件隔离安全沙箱中进行。"
          }
        }
      }
    },
    "Your chats, prompts, files, and keys never leave your Mac." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
