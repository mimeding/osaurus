          }
        }
      }
    },
    "The memory database isn't open. It may still be initializing, or it failed silently — try Retry." : {
      "comment" : "Detail text for the \"Memory DB open\" row when the memory database isn't open.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die Speicherdatenbank ist nicht geöffnet. Es kann immer noch initialisiert werden, oder es ist stillschweigend fehlgeschlagen - versuchen Sie es erneut."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内存数据库未打开。它可能仍在初始化，或者已静默失败——请尝试重试。"
          }
        }
      }
    },
    "The model is large; keep this window open while it downloads." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Modell ist groß; lass dieses Fenster geöffnet, während es heruntergeladen wird."
