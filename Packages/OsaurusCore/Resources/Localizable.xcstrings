    "privacy.review.subtitle" : {
      "comment" : "A subtitle explaining the purpose of the privacy review sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Elemente werden durch Platzhalter ersetzt, bevor deine Nachricht deinen Mac verlässt. Deaktiviere alles, was du lieber unverändert senden möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These items will be replaced with placeholders before your message leaves your Mac. Toggle off anything you'd rather send as-is."
