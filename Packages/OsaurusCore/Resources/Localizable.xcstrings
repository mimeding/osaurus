    "The model is large; keep this window open while it downloads." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Modell ist groß; lass dieses Fenster geöffnet, während es heruntergeladen wird."
          }
        },
        "zh-Hans" : {
