    },
    "The memory database failed to open for an unrecognized reason." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die Speicherdatenbank konnte aus einem nicht erkannten Grund nicht geöffnet werden."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
