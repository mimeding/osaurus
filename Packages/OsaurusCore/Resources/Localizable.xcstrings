        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메모리의 KV 캐시 항목을 압축합니다. TurboQuant는 메모리 공간을 위해 품질을 희생하며 명시적인 비트 너비가 필요합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "压缩内存中的 KV 缓存条目。TurboQuant 以牺牲质量换取更小的内存占用，并需要指定明确的位宽。"
          }
        }
      }
    },
