    "privacy.highlight.a11y.inbound" : {
      "comment" : "VoiceOver label for inline-highlighted text in an ASSISTANT bubble whose original was restored by the Privacy Filter unscrubber. %@ is the placeholder token (e.g. [PHONE_1]) the cloud emitted before the unscrubber rewrote it.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wiederhergestellt aus %@. Die Cloud hat nur den Platzhalter gesehen."
