    "Fill these in only for servers that don't advertise OAuth metadata. Both the authorize and token URLs must be set to skip discovery." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fülle diese nur für Server aus, die keine OAuth-Metadaten bereitstellen. Sowohl die Authorize- als auch die Token-URL müssen gesetzt sein, um die Erkennung zu überspringen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅为不公布 OAuth 元数据的服务器填写这些内容。必须同时设置授权 URL 和令牌 URL 才能跳过发现过程。"
          }
        }
      }
