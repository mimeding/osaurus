    },
    "This chat runs on the remote agent's own model — chosen by the agent's owner and not changeable here." : {
      "comment" : "Localized help text for the non-interactive model label in Mode 2 (remote agent run).",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "This chat runs on the remote agent's own model — chosen by the agent's owner and not changeable here."
