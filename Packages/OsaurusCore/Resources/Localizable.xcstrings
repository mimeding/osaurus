      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Port, Netzwerkfreigabe, CORS, top-P, Modell-Eviction und Leerlauf-Residenz befinden sich jetzt unter Server → Einstellungen, gestützt auf den vmlx-Server-Runtime-Vertrag."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
