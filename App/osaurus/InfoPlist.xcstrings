      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus verwendet das Mikrofon für die Spracherkennung auf dem Gerät mit FluidAudio."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus uses the microphone for on-device voice transcription with FluidAudio."
